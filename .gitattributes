# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Python files
*.py text eol=lf

# Documentation
*.md text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
.gitignore text eol=lf
.dockerignore text eol=lf

# Windows scripts (if any)
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.pkl binary
*.pt binary
*.pth binary
